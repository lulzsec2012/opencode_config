{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "../../instructions/behavior.md"
  ],
  "mcp": {
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true
    }
  },
  "model": "deepseek/deepseek-v4-flash",
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "oh-my-openagent@latest",
    "opencode-agent-context",
    "opencode-autoresearch@latest",
    "opencode-codegraph",
    "opencode-headroom",
    "opencode-localmemory",
    "opencode-skill-creator",
    "opencode-yaml-hooks",
    "@dietrichgebert/ponytail"
  ],
  "provider": {
    "deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek 云端 (6 个高性能模块专用)",
      "options": {
        "baseURL": "https://api.deepseek.com/v1",
        "apiKey": "{env:DEEPSEEK_API_KEY}"
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash（云端保底）",
          "tools": true,
          "limit": {
            "context": 262144,
            "output": 65536
          }
        },
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro（云端高阶推理）",
          "tools": true,
          "limit": {
            "context": 262144,
            "output": 65536
          }
        }
      }
    },
    "mixapi": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "本地 vLLM 集群",
      "options": {
        "baseURL": "{env:MIXAPI_BASE_URL}",
        "apiKey": "{env:MIXAPI_API_KEY}",
        "timeout": 600000,
        "chunkTimeout": 300000
      },
      "models": {
        "qwen3.6-27b": {
          "name": "Qwen3.6 27B（本地, 262K, ~105 tok/s）",
          "tools": true,
          "limit": {
            "context": 262144,
            "output": 32768
          }
        },
        "gemma4-26b-fp8": {
          "name": "Gemma4 26B FP8（本地高速, 262K, ~260 tok/s）",
          "tools": true,
          "limit": {
            "context": 262144,
            "output": 32768
          }
        }
      }
    }
  },
  "small_model": "mixapi/gemma4-26b-fp8"
}
