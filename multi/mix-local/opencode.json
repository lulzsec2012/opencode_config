{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "../../instructions/behavior.md"
  ],
  "mcp": {
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    }
  },
  "model": "mixapi/qwen3.6-27b",
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "oh-my-openagent@latest",
    "opencode-agent-context",
    "opencode-codegraph",
    "opencode-localmemory",
    "opencode-skill-creator",
    "opencode-yaml-hooks"
  ],
  "provider": {
    "deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek 云端兜底 [mix-local]",
      "options": {
        "baseURL": "https://api.deepseek.com/v1",
        "apiKey": "{env:DEEPSEEK_API_KEY}"
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash（云端高性能兜底）",
          "tools": true,
          "limit": {
            "context": 262144,
            "output": 65536
          }
        }
      }
    },
    "mixapi": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MixAPI (本地 vLLM 集群) [mix-local]",
      "options": {
        "baseURL": "{env:MIXAPI_BASE_URL}",
        "apiKey": "{env:MIX_API_KEY}",
        "timeout": 600000,
        "chunkTimeout": 300000
      },
      "models": {
        "qwen3.6-27b": {
          "name": "Qwen3.6 27B (主力, TP4, MTP=5, 262K, prefix-caching)",
          "tools": true,
          "limit": {
            "context": 262144,
            "output": 32768
          }
        },
        "gemma4-26b-fp8": {
          "name": "Gemma4 26B FP8 (快速, TP2, 65K, prefix-caching)",
          "tools": true,
          "limit": {
            "context": 65536,
            "output": 32768
          }
        }
      }
    }
  },
  "small_model": "mixapi/gemma4-26b-fp8"
}
