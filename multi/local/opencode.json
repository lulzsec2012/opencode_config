{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "../../instructions/behavior.md"
  ],
  "mcp": {
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    }
  },
  "model": "mixapi/qwen3.6-27b",
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "oh-my-openagent@latest",
    "opencode-agent-context",
    "opencode-codegraph",
    "opencode-localmemory",
    "opencode-skill-creator",
    "opencode-yaml-hooks"
  ],
  "provider": {
    "deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek 云端 [local - server]",
      "options": {
        "baseURL": "https://api.deepseek.com/v1",
        "apiKey": "{env:DEEPSEEK_API_KEY}"
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash（云端核心）",
          "tools": true,
          "limit": {
            "context": 262144,
            "output": 65536
          }
        }
      }
    },
    "mixapi": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MIX API 聚合 [ECS 39.102.52.1]",
      "options": {
        "baseURL": "http://39.102.52.1:3000/v1",
        "apiKey": "{env:MIX_API_KEY}"
      },
      "models": {
        "qwen3.6-27b": {
          "name": "Qwen3.6 27B（vLLM）",
          "tools": true,
          "limit": {
            "context": 65536,
            "output": 32768
          }
        },
        "gemma4-26b-fp8": {
          "name": "Gemma4 26B FP8（vLLM）",
          "tools": true,
          "limit": {
            "context": 65536,
            "output": 32768
          }
        }
      }
    }
  },
  "small_model": "mixapi/qwen3.6-27b"
}
