{
    "$schema": "https://opencode.ai/config.json",
    "lsp": true,
    "instructions": [
        "../../instructions/behavior.md"
    ],
    "mcp": {
        "codegraph": {
            "type": "local",
            "command": [
                "codegraph",
                "serve",
                "--mcp"
            ],
            "enabled": true
        },
        "ReVa": {
            "type": "local",
            "command": [
                "mcp-reva-wrapper"
            ],
            "enabled": true
        },
        "codebase-memory-mcp": {
            "type": "local",
            "command": [
                "codebase-memory-mcp"
            ],
            "enabled": false
        },
        "mcp-math-calculator": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "mcp-math-calculator"
            ],
            "enabled": true
        },
        "llm-router": {
            "type": "local",
            "command": [
                "llm-router-mcp"
            ],
            "enabled": true
        }
    },
    "model": "mixapi/qwen3.6-27b",
    "plugin": [
        "oh-my-openagent@latest",
        "opencode-agent-context",
        "opencode-autoresearch@latest",
        "opencode-codegraph",
        "opencode-debug-helper",
        "opencode-headroom",
        "opencode-localmemory",
        "opencode-qoder-auth",
        "opencode-skill-creator",
        "@dietrichgebert/ponytail",
        "caveman-opencode-plugin",
        "@arkfactory/opencode-checkpoint",
        "opencode-refactor-agent"
    ],
    "provider": {
        "mixapi": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "本地 vLLM 模型 (Local Only)",
            "options": {
                "baseURL": "http://localhost:8000/v1",
                "timeout": 600000,
                "chunkTimeout": 300000
            },
            "models": {
                "qwen3.6-27b": {
                    "name": "Qwen3.6 27B（本地, 262K, ~105 tok/s）",
                    "tools": true,
                    "limit": {
                        "context": 262144,
                        "output": 32768
                    }
                },
                "gemma4-26b-fp8": {
                    "name": "Gemma4 26B FP8（本地高速, 262K, ~260 tok/s）",
                    "tools": true,
                    "limit": {
                        "context": 262144,
                        "output": 32768
                    }
                }
            }
        }
    },
    "small_model": "mixapi/qwen3.6-27b",
    "formatter": true,
    "agent": {
        "refactor": {
            "color": "#55f76d",
            "description": "orchestrates safe refactors to improve code quality.",
            "mode": "primary",
            "permission": {
                "question": "allow"
            }
        }
    }
}