{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/refs/heads/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "deepseek/deepseek-v4-flash",
      "description": "调度核心（云端）",
      "maxTokens": 32768,
      "prompt_append": "You are an AI assistant. You must always respond in Simplified Chinese (中文). 你必须始终用中文回复用户。即使思考过程可以用英文，最终回复必须是中文。",
      "fallback_models": [
        "deepseek/deepseek-chat"
      ]
    },
    "prometheus": {
      "model": "deepseek/deepseek-v4-flash",
      "description": "规划（云端高阶推理）",
      "maxTokens": 16384,
      "prompt_append": "You are an AI assistant. You must always respond in Simplified Chinese (中文). 你必须始终用中文回复用户。即使思考过程可以用英文，最终回复必须是中文。",
      "fallback_models": [
        "deepseek/deepseek-chat"
      ]
    },
    "hephaestus": {
      "model": "deepseek/deepseek-v4-flash",
      "description": "代码执行核心",
      "maxTokens": 32768,
      "temperature": 0.2,
      "prompt_append": "You are an AI assistant. You must always respond in Simplified Chinese (中文). 你必须始终用中文回复用户。即使思考过程可以用英文，最终回复必须是中文。",
      "fallback_models": [
        "deepseek/deepseek-chat"
      ]
    },
    "momus": {
      "model": "deepseek/deepseek-v4-flash",
      "description": "质量裁判（云端审查）",
      "maxTokens": 16384,
      "temperature": 0.1,
      "prompt_append": "You are an AI assistant. You must always respond in Simplified Chinese (中文). 你必须始终用中文回复用户。即使思考过程可以用英文，最终回复必须是中文。",
      "fallback_models": [
        "deepseek/deepseek-chat"
      ]
    },
    "oracle": {
      "model": "deepseek/deepseek-v4-flash",
      "description": "只读分析（云端高阶推理）",
      "maxTokens": 32768,
      "prompt_append": "",
      "fallback_models": [
        "deepseek/deepseek-chat"
      ]
    },
    "explore": {
      "model": "deepseek/deepseek-v4-flash",
      "description": "代码库搜索",
      "maxTokens": 8192,
      "prompt_append": "",
      "fallback_models": [
        "deepseek/deepseek-chat"
      ]
    },
    "metis": {
      "model": "deepseek/deepseek-v4-flash",
      "description": "风险分析",
      "maxTokens": 16384,
      "prompt_append": "",
      "fallback_models": [
        "deepseek/deepseek-chat"
      ]
    },
    "librarian": {
      "model": "deepseek/deepseek-v4-flash",
      "description": "文档搜索",
      "maxTokens": 8192,
      "prompt_append": "",
      "fallback_models": [
        "deepseek/deepseek-chat"
      ]
    }
  },
  "background_task": {
    "defaultConcurrency": 3
  },
  "default_agent": "sisyphus",
  "hashline_edit": true
}
