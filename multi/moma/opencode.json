{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "instructions": [
    "../../instructions/behavior.md"
  ],
  "mcp": {
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    },
    "ReVa": {
      "type": "local",
      "command": [
        "mcp-reva-wrapper"
      ],
      "enabled": true
    },
    "codebase-memory-mcp": {
      "type": "local",
      "command": [
        "codebase-memory-mcp"
      ],
      "enabled": true
    },
    "mcp-math-calculator": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-math-calculator"
      ],
      "enabled": true
    },
    "llm-router": {
      "type": "local",
      "command": [
        "llm-router-mcp"
      ],
      "enabled": true
    }
  },
  "model": "jiutian/nvidia/nemotron-3-super-120b-a12b",
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "opencode-dcp-dynamic-limits",
    "opencode-debug-helper",
    "opencode-headroom",
    "oh-my-openagent@latest",
    "opencode-agent-context",
    "opencode-autoresearch@latest",
    "opencode-codegraph",
    "opencode-localmemory",
    "opencode-qoder-auth",
    "opencode-skill-creator",
    "@dietrichgebert/ponytail",
    "opencode-skills-collection",
    "caveman-opencode-plugin",
    "@arkfactory/opencode-checkpoint",
    "opencode-refactor-agent",
    "opencode-mission-control",
    "@cometjc/opencode-py-indent-guard"
  ],
  "provider": {
    "mixapi": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MixAPI \u672c\u5730 (llm-router MCP)",
      "options": {
        "baseURL": "http://localhost:8000/v1",
        "timeout": 600000,
        "chunkTimeout": 300000
      },
      "models": {
        "gemma4-26b-fp8": {
          "name": "Gemma4 26B FP8 (109 t/s, TTFT=0.14s)",
          "tools": true
        },
        "qwen3.6-27b": {
          "name": "Qwen3.6 27B (61 t/s, TTFT=0.24s)",
          "tools": true
        }
      }
    },
    "jiutian": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "\u4e5d\u5929\u6a21\u578b\u5e73\u53f0 (jiutian-moma)",
      "options": {
        "baseURL": "https://jiutian.10086.cn/largemodel/moma/api/v3",
        "apiKey": "{env:JIUTIAN_API_KEY}"
      },
      "_models": "\u4ee5\u4e0b\u4ec5\u4fdd\u7559\u6d4b\u901f\u901a\u8fc7\u7684\u7a33\u5b9a\u6a21\u578b\uff0c\u5931\u8d25\u7684\u5df2\u79fb\u81f3 _disabled_models",
      "models": {
        "z.ai/glm-5.1": {
          "name": "GLM-5.1 (\u6587\u6863\u751f\u6210 docx/pdf/xlsx\uff0c33 t/s)",
          "tools": true
        },
        "z.ai/glm-5.2": {
          "name": "GLM-5.2 (\u5f00\u6e90Agentic SOTA\uff0c\u5e26fallback\u4fdd\u969c)",
          "tools": true
        },
        "deepseek/deepseek-r1": {
          "name": "DeepSeek R1 (\u7eaf\u63a8\u7406\u6a21\u578b)"
        },
        "qwen/qwen3-coder-next": {
          "name": "Qwen3 Coder Next (80B/3B active\uff0c\u9ad8\u6548\u7f16\u7801)",
          "tools": true
        },
        "moonshotai/kimi-k2.6": {
          "name": "Kimi K2.6 (\u957f\u5468\u671f\u7f16\u7801\u738b\u8005\uff0cTerminal-Bench 66.7)",
          "tools": true
        },
        "minimax/minimax-m2.7": {
          "name": "MiniMax M2.7 (SRE/DevOps\uff0cGDPval-AA 1495)",
          "tools": true
        },
        "minimax/minimax-latest": {
          "name": "MiniMax Latest (16.2 t/s)",
          "tools": true
        },
        "nvidia/nemotron-3-super-120b-a12b": {
          "name": "NVIDIA Nemotron 120B (1M\u4e0a\u4e0b\u6587\uff0c95 t/s)",
          "tools": true
        },
        "openai/gpt-oss-120b": {
          "name": "GPT-OSS 120B (119 t/s \u901f\u5ea6\u4e4b\u738b)",
          "tools": true
        },
        "jiutian/jiutian-code-8b": {
          "name": "\u4e5d\u5929Code 8B (TTFT=0.9s \u4ee3\u7801\u6781\u901f\u641c\u7d22)",
          "tools": true
        },
        "jiutian/jiutian-math-8b": {
          "name": "\u4e5d\u5929Math 8B (\u6570\u5b66\u4e13\u4e1a\uff0c31 t/s)",
          "tools": true
        },
        "jiutian/jiutian-lan-13b": {
          "name": "\u4e5d\u5929\u84dd 13B (TTFT=0.8s \u6700\u5feb\u54cd\u5e94)",
          "tools": true
        },
        "z.ai/glm-5": {
          "name": "GLM-5",
          "tools": true
        },
        "deepseek/deepseek-v3": {
          "name": "DeepSeek V3",
          "tools": true
        },
        "deepseek/deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash",
          "tools": true
        },
        "moonshotai/kimi-k2.5-thinking": {
          "name": "Kimi K2.5 Thinking",
          "tools": true
        }
      }
    }
  },
  "small_model": "mixapi/gemma4-26b-fp8",
  "formatter": true,
  "agent": {
    "refactor": {
      "color": "#55f76d",
      "description": "orchestrates safe refactors to improve code quality.",
      "mode": "primary",
      "permission": {
        "question": "allow"
      }
    }
  }
}
