{
    "$schema": "https://opencode.ai/config.json",
    "lsp": true,
    "instructions": [
        "../../instructions/behavior.md"
    ],
    "mcp": {
        "codegraph": {
            "type": "local",
            "command": [
                "codegraph",
                "serve",
                "--mcp"
            ],
            "enabled": true
        },
        "sequential-thinking": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@modelcontextprotocol/server-sequential-thinking"
            ],
            "enabled": true
        },
        "ReVa": {
            "type": "local",
            "command": [
                "mcp-reva-wrapper"
            ],
            "enabled": true
        },
        "codebase-memory-mcp": {
            "type": "local",
            "command": [
                "codebase-memory-mcp"
            ],
            "enabled": true
        },
        "mcp-math-calculator": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "mcp-math-calculator"
            ],
            "enabled": true
        },
        "llm-router": {
            "type": "local",
            "command": [
                "python3",
                "scripts/llm-router-mcp.py"
            ],
            "enabled": true
        }
    },
    "model": "deepseek/deepseek-v4-flash",
    "plugin": [
        "@tarquinen/opencode-dcp@latest",
        "opencode-dcp-dynamic-limits",
        "opencode-debug-helper",
        "opencode-headroom",
        "oh-my-openagent@latest",
        "opencode-agent-context",
        "opencode-autoresearch@latest",
        "opencode-codegraph",
        "opencode-localmemory",
        "opencode-qoder-auth",
        "opencode-skill-creator",
        "@dietrichgebert/ponytail",
        "opencode-skills-collection",
        "caveman-opencode-plugin",
        "@arkfactory/opencode-checkpoint",
        "opencode-refactor-agent"
    ],
    "provider": {
        "deepseek": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "DeepSeek 云端主力 [mix-work]",
            "options": {
                "baseURL": "https://api.deepseek.com/v1",
                "apiKey": "{env:DEEPSEEK_API_KEY}"
            },
            "models": {
                "deepseek-v4-flash": {
                    "name": "DeepSeek V4 Flash（云端主力）",
                    "tools": true
                },
                "deepseek-v4-pro": {
                    "name": "DeepSeek V4 Pro（云端高阶推理）",
                    "tools": true
                }
            }
        },
        "mixapi": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "MixAPI 本地保底 [mix-work]",
            "options": {
                "baseURL": "http://localhost:8000/v1",
                "timeout": 600000,
                "chunkTimeout": 300000
            },
            "models": {
                "qwen3.6-27b": {
                    "name": "Qwen3.6 27B (长上下文推理, TP2×2, 262K, SWE-bench 77.2%)",
                    "tools": true,
                    "limit": {
                        "context": 262144,
                        "output": 32768
                    }
                },
                "gemma4-26b-fp8": {
                    "name": "Gemma4 26B FP8 (本地快速, ~260 tok/s, 262K)",
                    "tools": true,
                    "limit": {
                        "context": 262144,
                        "output": 32768
                    }
                }
            }
        }
    },
    "small_model": "mixapi/qwen3.6-27b",
    "formatter": true,
    "agent": {
        "refactor": {
            "color": "#55f76d",
            "description": "orchestrates safe refactors to improve code quality.",
            "mode": "primary",
            "permission": {
                "question": "allow"
            }
        }
    }
}