{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "../../instructions/behavior.md"
  ],
  "mcp": {
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    }
  },
  "model": "deepseek/deepseek-v4-flash",
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "oh-my-openagent@latest",
    "opencode-agent-context",
    "opencode-codegraph",
    "opencode-localmemory",
    "opencode-skill-creator",
    "opencode-yaml-hooks"
  ],
  "provider": {
    "deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek 云端主力 [mix-work]",
      "options": {
        "baseURL": "https://api.deepseek.com/v1",
        "apiKey": "{env:DEEPSEEK_API_KEY}"
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash（云端工作主力）",
          "tools": true,
          "limit": {
            "context": 262144,
            "output": 65536
          }
        }
      }
    },
    "mixapi": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MixAPI 本地保底 [mix-work]",
      "options": {
        "baseURL": "{env:MIXAPI_BASE_URL}",
        "apiKey": "{env:MIX_API_KEY}",
        "timeout": 600000,
        "chunkTimeout": 300000
      },
      "models": {
        "qwen3.6-27b": {
          "name": "Qwen3.6 27B (长上下文推理, TP2×2, 262K, SWE-bench 77.2%)",
          "tools": true,
          "limit": {
            "context": 262144,
            "output": 32768
          }
        },
        "gemma4-26b-awq-int4": {
          "name": "Gemma4 26B AWQ (快速, TP2, 115K, TTFT~120ms)",
          "tools": true,
          "limit": {
            "context": 114688,
            "output": 32768
          }
        }
      }
    }
  },
  "small_model": "mixapi/qwen3.6-27b"
}
