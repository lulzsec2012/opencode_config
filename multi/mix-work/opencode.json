{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama \u672c\u5730",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      },
      "models": {
        "qwen3-coder-next:latest": {
          "name": "Qwen3 Coder Next \u4e3b\u529b\u6a21\u578b",
          "tools": true,
          "limit": {
            "context": 262144,
            "output": 32768
          }
        },
        "qwen3.6:27b": {
          "name": "Qwen3.6 27B \u9ad8\u9636\u63a8\u7406",
          "tools": true,
          "limit": {
            "context": 262144,
            "output": 32768
          }
        },
        "qwen2.5-coder:14b": {
          "name": "Qwen2.5 Coder 14B \u8f7b\u91cf",
          "tools": true,
          "limit": {
            "context": 32768,
            "output": 8192
          }
        }
      }
    },
    "deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek \u4e91\u7aef\u6838\u5fc3 [mix-work]",
      "options": {
        "baseURL": "https://api.deepseek.com/v1",
        "apiKey": "{env:DEEPSEEK_API_KEY}"
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash\uff08\u4e91\u7aef\u6838\u5fc3\uff09",
          "tools": true,
          "limit": {
            "context": 262144,
            "output": 65536
          }
        }
      }
    }
  },
  "instructions": ["../../instructions/behavior.md"],
  "model": "deepseek/deepseek-v4-flash",
  "small_model": "ollama/qwen2.5-coder:14b",
  "plugin": [
    "oh-my-openagent@latest",
    "opencode-agent-context",
    "opencode-skill-creator",
    "@tarquinen/opencode-dcp@latest",
    "opencode-yaml-hooks"
