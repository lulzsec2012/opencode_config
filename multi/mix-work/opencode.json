{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "../../instructions/behavior.md"
  ],
  "mcp": {
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    }
  },
  "model": "deepseek/deepseek-v4-flash",
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "oh-my-openagent@latest",
    "opencode-agent-context",
    "opencode-codegraph",
    "opencode-localmemory",
    "opencode-skill-creator",
    "opencode-yaml-hooks"
  ],
  "provider": {
    "deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek 云端核心 [mix-work]",
      "options": {
        "baseURL": "https://api.deepseek.com/v1",
        "apiKey": "{env:DEEPSEEK_API_KEY}"
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash（云端核心）",
          "tools": true,
          "limit": {
            "context": 262144,
            "output": 65536
          }
        }
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama 本地",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      },
      "models": {
        "qwen3-coder-next:latest": {
          "name": "Qwen3 Coder Next 主力模型",
          "tools": true,
          "limit": {
            "context": 262144,
            "output": 32768
          }
        },
        "qwen3.6:27b": {
          "name": "Qwen3.6 27B 高阶推理",
          "tools": true,
          "limit": {
            "context": 262144,
            "output": 32768
          }
        },
        "qwen2.5-coder:14b": {
          "name": "Qwen2.5 Coder 14B 轻量",
          "tools": true,
          "limit": {
            "context": 32768,
            "output": 8192
          }
        }
      }
    }
  },
  "small_model": "ollama/qwen2.5-coder:14b"
}
