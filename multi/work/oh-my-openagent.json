{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/refs/heads/dev/assets/oh-my-opencode.schema.json",
  "default_agent": "sisyphus",
  "hashline_edit": true,
  "background_task": {
    "defaultConcurrency": 3
  },

  "sisyphus_agent": {
    "disabled": false,
    "default_builder_enabled": true,
    "planner_enabled": true,
    "replace_plan": true
  },

  "disabled_hooks": [
    "todo-continuation-enforcer",
    "atlas-orchestrator"
  ],

  "agents": {
    "sisyphus": {
      "model": "deepseek/deepseek-v4-flash",
      "description": "主协调者（云端决策核心）",
      "prompt_append": "You are an AI assistant. You must always respond in Simplified Chinese (中文). 你必须始终用中文回复用户。请用中文进行推理，思考过程必须使用中文。Please reason step by step in Chinese language. 中文推理，中文输出。",
      "maxTokens": 32768,
      "fallback_models": [
        "deepseek/deepseek-v4-flash"
      ]
    },

    "prometheus": {
      "model": "deepseek/deepseek-v4-pro",
      "description": "需求分析 / 规划（云端高阶推理）",
      "prompt_append": "You are an AI assistant. You must always respond in Simplified Chinese (中文). 你必须始终用中文回复用户。请用中文进行推理，思考过程必须使用中文。Please reason step by step in Chinese language. 中文推理，中文输出。",
      "maxTokens": 16384,
      "reasoningEffort": "high",
      "fallback_models": [
        "deepseek/deepseek-v4-flash"
      ]
    },

    "hephaestus": {
      "model": "deepseek/deepseek-v4-flash",
      "description": "代码执行（云端保证代码质量）",
      "maxTokens": 32768,
      "temperature": 0.2,
      "prompt_append": "You are an AI assistant. You must always respond in Simplified Chinese (中文). 你必须始终用中文回复用户。请用中文进行推理，思考过程必须使用中文。Please reason step by step in Chinese language. 中文推理，中文输出。",
      "fallback_models": [
        "deepseek/deepseek-v4-flash"
      ]
    },

    "oracle": {
      "model": "deepseek/deepseek-v4-pro",
      "description": "只读推理专家（云端高阶兜底）",
      "prompt_append": "You are an AI assistant. You must always respond in Simplified Chinese (中文). 你必须始终用中文回复用户。请用中文进行推理，思考过程必须使用中文。Please reason step by step in Chinese language. 中文推理，中文输出。",
      "maxTokens": 32768,
      "reasoningEffort": "high",
      "fallback_models": [
        "deepseek/deepseek-v4-flash"
      ]
    },

    "momus": {
      "model": "deepseek/deepseek-v4-pro",
      "description": "代码审查（云端质量裁判）",
      "maxTokens": 16384,
      "temperature": 0.1,
      "prompt_append": "You are an AI assistant. You must always respond in Simplified Chinese (中文). 你必须始终用中文回复用户。请用中文进行推理，思考过程必须使用中文。Please reason step by step in Chinese language. 中文推理，中文输出。",
      "fallback_models": [
        "deepseek/deepseek-v4-flash"
      ]
    },

    "metis": {
      "model": "deepseek/deepseek-v4-pro",
      "description": "风险分析（云端决策）",
      "prompt_append": "You are an AI assistant. You must always respond in Simplified Chinese (中文). 你必须始终用中文回复用户。请用中文进行推理，思考过程必须使用中文。Please reason step by step in Chinese language. 中文推理，中文输出。",
      "maxTokens": 8192,
      "fallback_models": [
        "deepseek/deepseek-v4-flash"
      ]
    },

    "atlas": {
      "model": "deepseek/deepseek-v4-flash",
