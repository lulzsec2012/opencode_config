{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "instructions": [
    "../../instructions/behavior.md"
  ],
  "mcp": {
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true
    },
    "ReVa": {
      "type": "local",
      "command": ["mcp-reva-wrapper"],
      "enabled": true
    },
    "codebase-memory-mcp": {
      "type": "local",
      "command": ["codebase-memory-mcp"],
      "enabled": false
    },
    "mcp-math-calculator": {
      "type": "local",
      "command": ["npx", "-y", "mcp-math-calculator"],
      "enabled": true
    }
  },
  "model": "deepseek/deepseek-v4-flash",
    "plugin": [
        "opencode-debug-helper",
        "@tarquinen/opencode-dcp@latest",
        "opencode-dcp-dynamic-limits",
        "oh-my-openagent@latest",
        "opencode-agent-context",
        "opencode-autoresearch@latest",
        "opencode-codegraph",
        "opencode-localmemory",
        "opencode-qoder-auth",
        "opencode-skill-creator",
        "caveman-opencode-plugin",
        "@arkfactory/opencode-checkpoint"
    ],
  "provider": {
    "deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek 云端主力 [work]",
      "options": {
        "baseURL": "https://api.deepseek.com/v1",
        "apiKey": "{env:DEEPSEEK_API_KEY}",
        "timeout": 600000,
        "chunkTimeout": 300000
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash（云端工作主力）",
          "tools": true
        },
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro（云端高阶推理）",
          "tools": true
        }
      }
    },
    "mixapi": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MixAPI 本地保底 [work]",
      "options": {
        "baseURL": "{env:MIXAPI_BASE_URL}",
        "apiKey": "{env:MIXAPI_API_KEY}",
        "timeout": 600000,
        "chunkTimeout": 300000
      },
      "models": {
        "qwen3.6-27b": {
          "name": "Qwen3.6 27B（本地长上下文保底, 262K）",
          "tools": true,
          "limit": {
            "context": 262144,
            "output": 32768
          }
        }
      }
    }
  },
  "small_model": "mixapi/qwen3.6-27b"
}
