{
  "$schema": "https://raw.githubusercontent.com/Opencode-DCP/opencode-dynamic-context-pruning/master/dcp.schema.json",
  "enabled": true,
  "autoUpdate": true,
  "debug": false,
  "pruneNotification": "minimal",
  "compress": {
    "mode": "range",
    "permission": "allow",
    "showCompression": false,
    "summaryBuffer": true,
    "nudgeFrequency": 50,
    "modelMinLimits": {
      "deepseek-v4-flash": 222822,
      "gemma4-26b-fp8": 222822
    },
    "modelMaxLimits": {
      "deepseek-v4-flash": 222822,
      "gemma4-26b-fp8": 222822
    },
    "minContextLimit": 222822,
    "maxContextLimit": 222822,
    "iterationNudgeThreshold": 50,
    "nudgeForce": "soft",
    "modelLimits": {
      "deepseek-v4-flash": {
        "min": 222822,
        "max": 222822
      }
    },
    "activeModel": "deepseek-v4-flash"
  },
  "strategies": {
    "deduplication": {
      "enabled": true
    },
    "purgeErrors": {
      "enabled": true,
      "turns": 4
    }
  },
  "pruneNotificationType": "toast"
}
