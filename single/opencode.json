{
    "$schema": "https://opencode.ai/config.json",
    "lsp": true,
    "instructions": [
        "../instructions/behavior.md"
    ],
    "mcp": {
        "codegraph": {
            "type": "local",
            "command": [
                "codegraph",
                "serve",
                "--mcp"
            ],
            "enabled": false
        },
        "sequential-thinking": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@modelcontextprotocol/server-sequential-thinking"
            ],
            "enabled": true
        },
        "ReVa": {
            "type": "local",
            "command": [
                "mcp-reva-wrapper"
            ],
            "enabled": false
        },
        "codebase-memory-mcp": {
            "type": "local",
            "command": [
                "codebase-memory-mcp"
            ],
            "enabled": true
        },
        "mcp-math-calculator": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "mcp-math-calculator"
            ],
            "enabled": true
        }
    },
    "model": "deepseek/deepseek-v4-flash",
    "small_model": "deepseek/deepseek-v4-flash",
    "plugin": [
        "oh-my-openagent@latest",
        "opencode-agent-context",
        "opencode-autoresearch@latest",
        "opencode-codegraph",
        "opencode-headroom",
        "opencode-localmemory",
        "opencode-skill-creator",
        "opencode-yaml-hooks"
    ],
    "provider": {
        "deepseek": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "DeepSeek \u4E91\u7AEF",
            "options": {
                "baseURL": "https://api.deepseek.com/v1",
                "apiKey": "{env:DEEPSEEK_API_KEY}",
                "timeout": 600000,
                "chunkTimeout": 300000
            },
            "models": {
                "deepseek-v4-flash": {
                    "name": "DeepSeek V4 Flash\uFF08\u4E91\u7AEF\u4E3B\u529B\uFF09",
                    "tools": true,
                    "limit": {
                        "context": 262144,
                        "output": 65536
                    }
                },
                "deepseek-v4-pro": {
                    "name": "DeepSeek V4 Pro\uFF08\u4E91\u7AEF\u9AD8\u9636\u63A8\u7406\uFF09",
                    "tools": true,
                    "limit": {
                        "context": 262144,
                        "output": 65536
                    }
                }
            }
        }
    }
}
