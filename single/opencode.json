{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "../instructions/behavior.md"
  ],
  "mcp": {
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    }
  },
  "model": "deepseek/deepseek-v4-flash",
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "oh-my-openagent@latest",
    "opencode-autoresearch@latest",
    "opencode-codegraph",
    "opencode-localmemory",
    "opencode-yaml-hooks"
  ],
  "provider": {
    "deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek 云端",
      "options": {
        "baseURL": "https://api.deepseek.com/v1",
        "apiKey": "{env:DEEPSEEK_API_KEY}"
      },
      "models": {
        "deepseek-chat": {
          "name": "DeepSeek Chat",
          "tools": true
        },
        "deepseek-reasoner": {
          "name": "DeepSeek Reasoner",
          "tools": true
        },
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash",
          "tools": true,
          "limit": {
            "context": 262144,
            "output": 65536
          }
        }
      }
    }
  },
  "instructions": [
    "../instructions/behavior.md"
  ],
  "model": "deepseek/deepseek-v4-flash",
  "small_model": "deepseek/deepseek-chat",
  "mcp": {
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    }
  },
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "opencode-dcp-dynamic-limits",
    "oh-my-openagent@latest",
    "opencode-agent-context",
    "opencode-autoresearch@latest",
    "opencode-codegraph",
    "opencode-localmemory",
    "opencode-skill-creator",
    "opencode-yaml-hooks"
  ]
}
