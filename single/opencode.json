{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "../instructions/behavior.md"
  ],
  "mcp": {
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": false
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true
    }
  },
  "model": "deepseek/deepseek-v4-flash",
  "small_model": "deepseek/deepseek-v4-flash",
  "plugin": [
    "oh-my-openagent@latest",
    "opencode-agent-context",
    "opencode-autoresearch@latest",
    "opencode-codegraph",
    "opencode-headroom",
    "opencode-localmemory",
    "opencode-skill-creator",
    "opencode-yaml-hooks",
    "@dietrichgebert/ponytail"
  ],
  "provider": {
    "deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek 云端",
      "options": {
        "baseURL": "https://api.deepseek.com/v1",
        "apiKey": "{env:DEEPSEEK_API_KEY}",
        "timeout": 600000,
        "chunkTimeout": 300000
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash（云端主力）",
          "tools": true,
          "limit": {
            "context": 262144,
            "output": 65536
          }
        },
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro（云端高阶推理）",
          "tools": true,
          "limit": {
            "context": 262144,
            "output": 65536
          }
        }
      }
    }
  }
}
